{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hardline_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking hardlines"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh",
    "symlinkDirectories": ["cruise_ai-mcp/node_modules"],
    "bgIsolation": "worktree"
  }
}
